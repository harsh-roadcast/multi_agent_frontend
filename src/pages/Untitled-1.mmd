AgentOrchestratorService --> ExecutionDelegationService
AgentOrchestratorService --> MergeService
AgentOrchestratorService --> ValidationLoopService

ExecutionDelegationService --> SqlSourceAgent
ExecutionDelegationService --> StructuredDataSourceAgent
ExecutionDelegationService --> DocumentSourceAgent

%% Agent internals
